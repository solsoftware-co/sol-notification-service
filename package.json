{
  "name": "sol-notification-service",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "concurrently --names \"server,inngest\" --prefix-colors \"cyan,yellow\" --kill-others-on-fail \"tsx watch --env-file .env.local src/index.ts\" \"npx inngest-cli@latest dev -u http://localhost:3000/api/inngest\"",
    "build": "tsc",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "db:migrate": "tsx --env-file .env.local scripts/migrate.ts",
    "db:migrate:status": "tsx --env-file .env.local scripts/migrate.ts --status",
    "db:seed": "tsx --env-file .env.local scripts/seed-data.ts",
    "email:preview": "tsx --env-file .env.local scripts/test-email-preview.ts",
    "test:form": "tsx --env-file .env.local scripts/test-form-notification.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts"
  },
  "dependencies": {
    "@google-analytics/data": "^5.2.1",
    "@logtail/pino": "^0.5.8",
    "@neondatabase/serverless": "^1.0.2",
    "@react-email/components": "^1.0.8",
    "@react-email/render": "^2.0.4",
    "inngest": "^3.0.0",
    "nodemailer": "^7.0.13",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "resend": "^3.5.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@inngest/test": "^0.1.9",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^6.4.23",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^2.1.9",
    "concurrently": "^9.0.0",
    "mailtrap": "^4.4.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.1.9"
  }
}
