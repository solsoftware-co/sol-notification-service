# Environment
# Omit for development. Set to 'preview' or 'production' for other environments.
# VERCEL_ENV=production

# Email mode (auto-derived from VERCEL_ENV if not set)
#   development → mock  (console.log only, no real sends)
#   preview     → test  (redirect all emails to TEST_EMAIL)
#   production  → live  (deliver to real recipients)
# Override with EMAIL_MODE=mock|test|live
# EMAIL_MODE=mock

# Required when EMAIL_MODE=test
# TEST_EMAIL=your-test-inbox@example.com

# Required when EMAIL_MODE=live
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Sender address — must be a Resend-verified domain
RESEND_FROM=Notifications <notifications@yourdomain.com>

# Neon or local PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Better Stack log transport — leave absent in local dev (logger falls back to stdout JSON)
# Set LOGTAIL_SOURCE_TOKEN for Production and Preview in Vercel → Settings → Environment Variables
# LOGTAIL_SOURCE_TOKEN=
