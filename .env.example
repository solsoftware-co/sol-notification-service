# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and will never be committed.

# App server port (default: 3000)
PORT=3000

# Vercel deployment environment: development | preview | production
# Set automatically by Vercel in deployed environments.
VERCEL_ENV=development

# Email sending mode: mock (log only) | test (redirect) | live (real sends)
# development → mock, preview → test, production → live
EMAIL_MODE=mock

# Recipient address for test email redirects (preview environment only)
TEST_EMAIL=

# Inngest event key — not required for local dev (Dev Server handles auth)
# Get from https://app.inngest.com → Your App → Event Keys
INNGEST_EVENT_KEY=

# Inngest signing key — not required for local dev
# Get from https://app.inngest.com → Your App → Signing Keys
INNGEST_SIGNING_KEY=

# Neon Postgres connection string
# Local: postgresql://localhost:5432/notification_service_dev
# Neon: get from https://console.neon.tech
DATABASE_URL=

# Resend email provider API key
# Get from https://resend.com/api-keys
RESEND_API_KEY=

# Anthropic Claude API key (for AI-assisted workflows)
# Get from https://console.anthropic.com/settings/api-keys
ANTHROPIC_API_KEY=
